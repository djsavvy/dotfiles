{
  "permissions": {
    "deny": [
      "Glob",
      "Grep",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .:*)",
      "Bash(git add -u:*)",
      "Bash(git add --update:*)",
      "Bash(git add -A)",
      "Bash(git add --all)",
      "Bash(git add .)",
      "Bash(git add -u)",
      "Bash(git add --update)",
      "Bash(git commit -a:*)",
      "Bash(git commit -am:*)",
      "Bash(git commit --all:*)"
    ]
  },
  "model": "claude-opus-4-8",
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "editorMode": "vim",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "tui": "fullscreen"
}
